---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Privacy Policy" description="Basic privacy policy for OmniHex Lab.">
	<section class="page">
		<h1>Privacy Policy</h1>
		<p>
			OmniHex Lab is currently a static content site. It does not provide account login, does not store user profiles in a database, and does not require image uploads.
		</p>
		<p>
			Hosting, analytics, or third-party tools may process basic technical access information. If comments, subscriptions, submissions, or analytics are added later, this page should be updated with the relevant data practices.
		</p>
	</section>
</PageLayout>
