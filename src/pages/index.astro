---
import DynamicSignals from '../components/DynamicSignals.astro';
import PostList from '../components/PostList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import PageLayout from '../layouts/PageLayout.astro';
import { getRepresentativePostsByCategories } from '../utils/posts';

const latestBriefs = (await getRepresentativePostsByCategories(['briefs'])).slice(0, 4);
const promptLibrary = (await getRepresentativePostsByCategories(['prompts'])).slice(0, 4);
const lifeOsGuides = (await getRepresentativePostsByCategories(['life', 'guides'])).slice(0, 4);
---

<PageLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="intro">
		<p class="eyebrow">OmniHex Lab</p>
		<h1>Multilingual AI briefs, practical prompts, and life operating guides.</h1>
		<p>
			Focused resources for reading faster, writing better prompts, and building practical personal systems with AI.
		</p>
	</section>

	<DynamicSignals />

	<section class="content-section">
		<div class="section-heading">
			<h2>Latest Briefs</h2>
			<a href="/briefs/">All briefs</a>
		</div>
		<PostList posts={latestBriefs} emptyMessage="No briefs published yet." />
	</section>

	<section class="content-section">
		<div class="section-heading">
			<h2>Prompt Library</h2>
			<a href="/prompts/">All prompts</a>
		</div>
		<PostList posts={promptLibrary} emptyMessage="No prompts published yet." />
	</section>

	<section class="content-section">
		<div class="section-heading">
			<h2>Life OS Guides</h2>
			<a href="/life/">All Life OS</a>
		</div>
		<PostList posts={lifeOsGuides} emptyMessage="No Life OS guides published yet." />
	</section>

	<section class="subscribe-cta" aria-labelledby="subscribe-heading">
		<p class="eyebrow">Subscribe</p>
		<h2 id="subscribe-heading">Get the next OmniHex Lab update</h2>
		<p>Follow new briefs, prompt patterns, and Life OS guides as the library grows.</p>
		<div class="cta-actions">
			<a class="button" href="/subscribe/">Subscribe</a>
			<a href="/rss.xml">RSS feed</a>
		</div>
	</section>
</PageLayout>

<style>
	.intro {
		padding: 2rem 0 1rem;
	}
	.eyebrow {
		margin: 0 0 0.5rem;
		color: var(--accent-dark);
		font-weight: 700;
	}
	.intro h1 {
		max-width: 920px;
		margin-bottom: 1rem;
		font-size: clamp(2.2rem, 5vw, 4rem);
	}
	.intro p:last-child {
		max-width: 760px;
		color: rgb(var(--gray));
		font-size: 1.1rem;
	}
	.content-section {
		margin-top: 3rem;
	}
	.section-heading {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.section-heading h2 {
		margin: 0;
		font-size: 1.6rem;
	}
	.subscribe-cta {
		border-top: 1px solid rgb(var(--gray-light));
		margin-top: 3rem;
		padding-top: 2rem;
	}
	.subscribe-cta h2 {
		margin-bottom: 0.6rem;
		font-size: 1.8rem;
	}
	.subscribe-cta p:not(.eyebrow) {
		max-width: 640px;
		color: rgb(var(--gray));
	}
	.cta-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.9rem;
	}
	.cta-actions a {
		font-weight: 700;
	}
	.cta-actions .button {
		border-radius: 6px;
		background: var(--accent);
		padding: 0.55rem 0.9rem;
		color: white;
		text-decoration: none;
	}
	.cta-actions .button:hover {
		background: var(--accent-dark);
	}
</style>
