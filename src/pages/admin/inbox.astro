---
import PageLayout from '../../layouts/PageLayout.astro';

const title = 'OmniHex Admin - Source Inbox';
const description = 'A future source collection workspace for OmniHex Lab.';
const futureFeatures = [
	'summarize source',
	'score relevance',
	'detect language',
	'suggest content type',
	'recommend target languages',
];
---

<PageLayout title={title} description={description}>
	<section class="admin-shell">
		<p class="prototype-warning">Prototype only. Do not share this URL publicly.</p>

		<header class="admin-header">
			<p class="eyebrow">Source Inbox</p>
			<h1>Collect Source Material</h1>
			<p>
				A private placeholder for gathering URLs and raw notes before AI analysis, editorial scoring, and draft
				creation are connected.
			</p>
		</header>

		<div class="inbox-grid">
			<form class="source-form">
				<div class="form-row">
					<label for="sourceUrl">Source URL</label>
					<input id="sourceUrl" name="sourceUrl" type="url" inputmode="url" />
				</div>

				<div class="form-row">
					<label for="rawText">Raw text</label>
					<textarea id="rawText" name="rawText" rows="16"></textarea>
				</div>

				<button type="button" disabled>Analyze with AI</button>
			</form>

			<aside class="future-panel" aria-labelledby="future-features-heading">
				<h2 id="future-features-heading">Future source analysis</h2>
				<ul>
					{futureFeatures.map((feature) => <li>{feature}</li>)}
				</ul>
			</aside>
		</div>
	</section>
</PageLayout>

<style>
	.admin-shell {
		display: grid;
		gap: 1.5rem;
	}

	.prototype-warning {
		margin: 0;
		border: 1px solid #f59e0b;
		border-radius: 8px;
		background: #fffbeb;
		color: #92400e;
		font-size: 0.95rem;
		font-weight: 700;
		padding: 0.7rem 0.9rem;
	}

	.admin-header {
		border-bottom: 1px solid rgb(var(--gray-light));
		padding-bottom: 1.25rem;
	}

	.eyebrow {
		margin: 0 0 0.4rem;
		color: var(--accent-dark);
		font-weight: 700;
	}

	.admin-header h1 {
		font-size: clamp(2rem, 4vw, 3.2rem);
	}

	.admin-header p:last-child {
		max-width: 780px;
		color: rgb(var(--gray));
		font-size: 1.06rem;
	}

	.inbox-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 320px;
		gap: 1.25rem;
		align-items: start;
	}

	.source-form,
	.future-panel {
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.92);
		box-shadow: 0 10px 30px rgba(var(--black), 6%);
		padding: 1.25rem;
	}

	.source-form {
		display: grid;
		gap: 1rem;
	}

	.form-row {
		display: grid;
		gap: 0.35rem;
	}

	label {
		color: rgb(var(--black));
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.3;
	}

	input,
	textarea {
		width: 100%;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		background: #fff;
		color: rgb(var(--gray-dark));
		font: inherit;
		line-height: 1.45;
		padding: 0.7rem 0.75rem;
	}

	input:focus,
	textarea:focus {
		border-color: var(--accent);
		outline: 3px solid rgba(37, 99, 235, 0.14);
	}

	textarea {
		min-height: 360px;
		resize: vertical;
	}

	button {
		width: fit-content;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		background: rgb(var(--gray-light));
		color: rgb(var(--gray));
		cursor: not-allowed;
		font: inherit;
		font-weight: 700;
		line-height: 1.2;
		padding: 0.75rem 1rem;
	}

	.future-panel h2 {
		font-size: 1.25rem;
	}

	.future-panel ul {
		margin: 0;
		padding-left: 1.1rem;
		color: rgb(var(--gray));
		font-size: 0.96rem;
	}

	.future-panel li + li {
		margin-top: 0.45rem;
	}

	@media (max-width: 900px) {
		.inbox-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
