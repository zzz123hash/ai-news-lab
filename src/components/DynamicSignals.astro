<section class="dynamic-signals" aria-labelledby="dynamic-signals-heading" data-dynamic-signals>
	<div class="signals-header">
		<p class="signals-eyebrow">AI Signals</p>
		<h2 id="dynamic-signals-heading">Dynamic AI Signals</h2>
	</div>
	<p class="signals-status" data-signals-status>Checking for fresh signals...</p>
	<ul class="signals-list" data-signals-list>
		<li class="signals-fallback">Explore the latest AI briefs, prompts, and Life OS guides.</li>
	</ul>
</section>

<script>
	const SIGNALS_ENDPOINT = 'https://api.lab.omnihex.xyz/public/signals';
	const SIGNALS_TIMEOUT_MS = 3000;
	const FALLBACK_TEXT = 'Explore the latest AI briefs, prompts, and Life OS guides.';

	function normalizeSignals(payload) {
		if (!payload || payload.ok !== true || !Array.isArray(payload.signals)) {
			return [];
		}

		return payload.signals
			.map((signal) => {
				if (!signal || typeof signal !== 'object') {
					return null;
				}

				const title = String(signal.title ?? '').trim();
				const summary = String(signal.summary ?? '').trim();
				const category = String(signal.category ?? '').trim();
				const language = String(signal.language ?? '').trim();

				if (!title || !summary) {
					return null;
				}

				return { title, summary, category, language };
			})
			.filter(Boolean)
			.slice(0, 5);
	}

	function renderSignals(list, signals) {
		list.replaceChildren(...signals.map((signal) => {
			const item = document.createElement('li');
			item.className = 'signals-card';

			const title = document.createElement('strong');
			title.textContent = signal.title;
			item.append(title);

			const summary = document.createElement('p');
			summary.textContent = signal.summary;
			item.append(summary);

			const metaParts = [signal.category, signal.language].filter(Boolean);

			if (metaParts.length > 0) {
				const meta = document.createElement('span');
				meta.className = 'signals-meta';
				meta.textContent = metaParts.join(' / ');
				item.append(meta);
			}

			return item;
		}));
	}

	function renderFallback(list) {
		const item = document.createElement('li');
		item.className = 'signals-fallback';
		item.textContent = FALLBACK_TEXT;
		list.replaceChildren(item);
	}

	async function loadSignals(root) {
		const status = root.querySelector('[data-signals-status]');
		const list = root.querySelector('[data-signals-list]');

		if (!(status instanceof HTMLElement) || !(list instanceof HTMLElement)) {
			return;
		}

		const controller = new AbortController();
		const timeoutId = window.setTimeout(() => controller.abort(), SIGNALS_TIMEOUT_MS);

		try {
			const response = await fetch(SIGNALS_ENDPOINT, {
				headers: { Accept: 'application/json' },
				signal: controller.signal,
			});

			if (!response.ok) {
				throw new Error(`Signals API returned ${response.status}`);
			}

			const signals = normalizeSignals(await response.json());

			if (signals.length === 0) {
				throw new Error('Signals API returned no usable signals');
			}

			renderSignals(list, signals);
			status.textContent = 'Fresh signals loaded.';
			root.dataset.state = 'loaded';
		} catch {
			renderFallback(list);
			status.textContent = 'Static signals available.';
			root.dataset.state = 'fallback';
		} finally {
			window.clearTimeout(timeoutId);
		}
	}

	for (const root of document.querySelectorAll('[data-dynamic-signals]')) {
		if (root instanceof HTMLElement) {
			loadSignals(root);
		}
	}
</script>

<style>
	.dynamic-signals {
		border-top: 1px solid rgb(var(--gray-light));
		border-bottom: 1px solid rgb(var(--gray-light));
		margin: 1.5rem 0 0;
		padding: 1.25rem 0;
	}

	.signals-header {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.5rem 1rem;
	}

	.signals-eyebrow {
		margin: 0;
		color: var(--accent-dark);
		font-size: 0.9rem;
		font-weight: 700;
	}

	.dynamic-signals h2 {
		margin: 0;
		font-size: 1.35rem;
	}

	.signals-status {
		width: fit-content;
		margin: 0.85rem 0 0;
		border-radius: 999px;
		background: rgb(var(--gray-light));
		color: rgb(var(--gray));
		font-size: 0.82rem;
		font-weight: 700;
		line-height: 1.2;
		padding: 0.3rem 0.65rem;
	}

	.dynamic-signals[data-state='loaded'] .signals-status {
		background: rgba(37, 99, 235, 0.1);
		color: var(--accent-dark);
	}

	.signals-list {
		display: grid;
		gap: 0.6rem;
		margin: 1rem 0 0;
		padding: 0;
		list-style: none;
	}

	.signals-list li {
		border-left: 3px solid var(--accent);
		padding-left: 0.75rem;
		color: rgb(var(--gray-dark));
	}

	.signals-card {
		display: grid;
		gap: 0.25rem;
	}

	.signals-card strong {
		color: rgb(var(--black));
		line-height: 1.3;
	}

	.signals-card p {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.95rem;
		line-height: 1.55;
	}

	.signals-meta {
		color: var(--accent-dark);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		text-transform: uppercase;
	}

	.dynamic-signals:not([data-state]) .signals-status::after {
		display: inline-block;
		width: 1.4em;
		content: '...';
		animation: signal-pulse 1.2s steps(3, end) infinite;
	}

	@keyframes signal-pulse {
		0% {
			opacity: 0.35;
		}
		50% {
			opacity: 1;
		}
		100% {
			opacity: 0.35;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.dynamic-signals:not([data-state]) .signals-status::after {
			animation: none;
			content: '';
		}
	}
</style>
