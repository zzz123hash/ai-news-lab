		color: rgb(var(--gray));
		font-size: 0.98rem;
		line-height: 1.6;
	}

	.signals-status {
		flex: 0 0 auto;
		margin: 0;
		border-radius: 999px;
		background: rgba(var(--gray-light), 0.72);
