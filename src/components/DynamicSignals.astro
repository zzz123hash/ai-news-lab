			opacity: 0.35;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.dynamic-signals:not([data-state]) .signals-status::after {
			animation: none;
			content: '';
		}

		.signals-card {
			transition: none;
		}

		.signals-card:hover {
