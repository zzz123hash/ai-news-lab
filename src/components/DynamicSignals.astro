		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.signals-fallback {
		grid-column: 1 / -1;
		border-style: dashed;
		color: rgb(var(--gray));
		font-size: 0.98rem;
	}

	.dynamic-signals:not([data-state]) .signals-status::after {
